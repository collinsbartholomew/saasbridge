# ─── Nextbase: environment variables ──────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values.
# Required vars throw a clear error at boot if missing (see src/lib/env.ts).

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres connection string. Sign up at https://console.neon.tech and
# create a project. The "Pooled connection" string is recommended for serverless.
DATABASE_URL="postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
# 32+ char random secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public origin of this app. Set to your production URL when deployed.
BETTER_AUTH_URL="http://localhost:3000"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get an API key at https://resend.com/api-keys
# In development this is OPTIONAL: if unset, OTP codes are printed to the console.
# In production this is REQUIRED to send OTP emails.
RESEND_API_KEY=""
# Must match a verified sender on your Resend account.
EMAIL_FROM="Nextbase <onboarding@resend.dev>"

# ─── AI Gateway (optional) ────────────────────────────────────────────────────
# Uncomment and set to enable AI features. Get a key from
# https://vercel.com/docs/ai-gateway. See docs/add-ai-later.md for details.
# AI_GATEWAY_API_KEY=""

# ─── Public (exposed to browser) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Nextbase"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
